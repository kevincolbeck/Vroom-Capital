# Legion Bot — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git

# ── Bitunix API (get from Bitunix → Account → API Management) ──
BITUNIX_API_KEY=your_api_key_here
BITUNIX_API_SECRET=your_api_secret_here

# ── Admin Dashboard ──────────────────────────────────────
ADMIN_PASSWORD=change_me_to_something_strong
SECRET_KEY=generate_a_long_random_string_at_least_32_chars_here

# ── Bot Settings ─────────────────────────────────────────
BOT_ENABLED=false           # Set to true to auto-start trading on launch
COPY_TRADING_ENABLED=true
PAPER_TRADING=false         # Set to true for dry-run (no real orders placed)

# ── Strategy Defaults (all adjustable live in the admin UI) ──
LEVERAGE=86
POSITION_SIZE_PCT=0.30
LIQUIDATION_BUFFER_USD=4500.0
TP1_PCT=0.20
TP2_PCT=0.30
VELOCITY_THRESHOLD_PCT=1.5
ZONE_COOLDOWN_MINUTES=120

# ── Database ─────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/legion.db
